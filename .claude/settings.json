  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-secrets.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-canon.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-canon.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "if": "Skill(implement-loop)",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && npm run gen:types 2>&1 || echo '[hook] gen:types failed (continuing)'; touch \"$CLAUDE_PROJECT_DIR/.claude/.implement-loop-active\"",
            "shell": "bash",
            "timeout": 120,
            "statusMessage": "API型定義を生成中 (gen:types)..."
          },
          {
            "type": "command",
            "if": "Skill(review-implementation)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/fe-arch-check.sh",
            "shell": "bash",
            "timeout": 30,
            "statusMessage": "FEアーキテクチャを機械チェック中..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "if": "Skill(fix-implementation)",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && npm run format 2>&1 || true",
            "shell": "bash",
            "timeout": 60,
            "statusMessage": "コードをフォーマット中 (format)..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/.implement-loop-active\" ]; then rm -f \"$CLAUDE_PROJECT_DIR/.claude/.implement-loop-active\"; cd \"$CLAUDE_PROJECT_DIR\" && npm run format 2>&1 || true; fi",
            "shell": "bash",
            "timeout": 60,
            "statusMessage": "コードをフォーマット中 (format)..."
          }
        ]
      }
    ]
  }
}
