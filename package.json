{
  "name": "claude-poc-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.16.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
