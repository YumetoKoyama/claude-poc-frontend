# 本番ビルド（GitHub Actions）用環境変数
# 値は GitHub Actions の Repository secrets / variables から注入する
# このファイルは変数名の定義のみ記載し、値は空にしておく

# クライアントサイドからバックエンドを直接呼ぶベース URL
# GitHub Actions 変数: NEXT_PUBLIC_API_BASE_URL
NEXT_PUBLIC_API_BASE_URL=

# サーバーサイド（Route Handler）からバックエンドへの接続先
# GitHub Actions 変数: BACKEND_API_URL
BACKEND_API_URL=
